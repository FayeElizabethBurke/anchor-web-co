---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Websites that bring in work | Anchor Websites"
  description="We build fast, clean websites for tradies and small businesses in Australia. Modern redesigns, local SEO, and conversion-focused design. Get a free quote."
  keywords="websites for tradies, small business website design Australia, lead generating websites, tradie website, web design Australia, local SEO"
>
  <Header />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section class="min-h-[88vh] flex items-center py-24 sm:py-32">
      <div class="container-site w-full">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-16">

          <!-- Left: copy -->
          <div>
            <p class="section-label mb-8 animate-on-scroll">
              Web Design &middot; Local SEO &middot; Lead Generation
            </p>

            <h1 class="text-display-xl text-ink mb-8 animate-on-scroll" style="transition-delay: 0.08s">
              Websites that<br />
              bring in <span class="text-accent">work.</span>
            </h1>

            <p class="text-lg sm:text-xl text-muted leading-relaxed mb-10 animate-on-scroll" style="transition-delay: 0.16s">
              We build clean, fast websites for tradies and small businesses.
              No bloat. No templates. Just a site that turns visitors into customers.
            </p>

            <!-- Mobile CTA (hidden on desktop) -->
            <div class="flex flex-wrap gap-4 lg:hidden animate-on-scroll" style="transition-delay: 0.24s">
              <a href="#contact" class="btn-primary py-4 px-8"
                data-gtag-event="cta_click" data-gtag-label="hero_mobile">
                Get a free quote
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Right: form (desktop only) -->
          <div class="hidden lg:flex flex-col justify-center animate-on-scroll" style="transition-delay: 0.16s">
            <p class="section-label mb-4">Get a free quote</p>
            <ContactForm variant="light" />
          </div>

        </div>

        <!-- Built for — full width -->
        <div class="pt-8 border-t border-border animate-on-scroll" style="transition-delay: 0.24s">
          <p class="text-xs text-muted tracking-widest uppercase mb-4">Built for</p>
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-display font-medium text-ink/50">
            <span>Builders</span>
            <span>Plumbers</span>
            <span>Electricians</span>
            <span>Landscapers</span>
            <span>Painters</span>
            <span>Small businesses</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── WHAT WE DO ─────────────────────────────────────── -->
    <section id="services" class="py-24 sm:py-32 bg-white border-t border-border" data-track-section="services">
      <div class="container-site">

        <div class="mb-16 animate-on-scroll">
          <p class="section-label mb-4">What we do</p>
          <h2 class="text-display-lg text-ink max-w-lg">
            Three things,<br />done well.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
          {[
            {
              num: '01',
              title: 'Redesign',
              body: 'We take your outdated site and build something modern, fast, and conversion-ready. Clean code. Zero template.',
            },
            {
              num: '02',
              title: 'Local SEO',
              body: "We optimise your site so the right people find you when they search. More visibility in your area. More calls.",
            },
            {
              num: '03',
              title: 'Leads',
              body: "Every page is built with one goal: get people to contact you. Clear calls-to-action and a form that actually works.",
            },
          ].map((item, i) => (
            <div
              class="bg-white p-8 sm:p-10 animate-on-scroll"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <p class="text-xs font-display font-bold text-muted/40 mb-8 tracking-[0.2em]">{item.num}</p>
              <h3 class="text-display-md text-ink mb-5">{item.title}</h3>
              <p class="text-sm sm:text-base text-muted leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─── WHO IT'S FOR ───────────────────────────────────── -->
    <section class="py-24 sm:py-32 border-t border-border">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <div class="animate-on-scroll">
            <p class="section-label mb-4">Who it's for</p>
            <h2 class="text-display-lg text-ink mb-8">
              Built for people<br />who work hard.
            </h2>
            <p class="text-base text-muted leading-relaxed max-w-sm">
              If you're running a business and your website isn't pulling its weight, we can fix that — fast.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border">
            {[
              {
                type: 'Tradies',
                items: ['Builders', 'Plumbers', 'Electricians', 'Painters', 'Landscapers', 'Concreters'],
              },
              {
                type: 'Small Business',
                items: ['Cafes & Restaurants', 'Clinics & Health', 'Consultants', 'Retail', 'Fitness & Wellness', 'Professional Services'],
              },
            ].map((col, i) => (
              <div
                class="bg-paper p-8 animate-on-scroll"
                style={`transition-delay: ${i * 0.12}s`}
              >
                <h3 class="text-base font-display font-bold text-ink mb-6 tracking-tight">{col.type}</h3>
                <ul class="space-y-2.5">
                  {col.items.map((item) => (
                    <li class="flex items-center gap-2.5 text-sm text-muted">
                      <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ─── THE DIFFERENCE ─────────────────────────────────── -->
    <section class="py-24 sm:py-32 bg-ink text-paper border-t border-border" data-track-section="results">
      <div class="container-site">

        <div class="mb-16 animate-on-scroll">
          <p class="section-label text-paper/30 mb-4">Why it matters</p>
          <h2 class="text-display-lg text-paper max-w-2xl">
            Your website is your<br />best salesperson.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
          {[
            {
              stat: '2s',
              label: 'Target load time',
              body: 'Fast sites rank higher and keep visitors longer. We build for performance from day one.',
            },
            {
              stat: '90+',
              label: 'Lighthouse score',
              body: 'Google rewards fast, accessible sites. We build to score — which means more organic traffic for you.',
            },
            {
              stat: '2–4wk',
              label: 'Delivery time',
              body: 'No agencies with 3-month timelines. We work fast, keep you in the loop, and launch properly.',
            },
          ].map((item, i) => (
            <div
              class="bg-ink p-8 sm:p-10 animate-on-scroll"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <p class="font-display font-bold text-accent mb-2 tracking-tight" style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1;">{item.stat}</p>
              <p class="text-xs font-display font-bold uppercase tracking-[0.2em] text-paper/30 mb-6">{item.label}</p>
              <p class="text-sm text-paper/60 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─── PROCESS ─────────────────────────────────────────── -->
    <section id="process" class="py-24 sm:py-32 bg-white border-t border-border" data-track-section="process">
      <div class="container-site">

        <div class="mb-16 animate-on-scroll">
          <p class="section-label mb-4">How it works</p>
          <h2 class="text-display-lg text-ink max-w-lg">
            Simple process.<br />Real results.
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border">
          {[
            {
              step: '01',
              title: 'Talk',
              body: "Tell us about your business, who you serve, and what's not working with your current site.",
            },
            {
              step: '02',
              title: 'Plan',
              body: 'We map out the structure, copy direction, and a clear plan for how the site will generate leads.',
            },
            {
              step: '03',
              title: 'Build',
              body: 'We build your new site — clean code, fast performance, and a design that reflects your business.',
            },
            {
              step: '04',
              title: 'Launch',
              body: "We go live. We handle the technical side so everything is set up correctly from day one.",
            },
          ].map((item, i) => (
            <div
              class="bg-white p-8 sm:p-10 animate-on-scroll"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <p class="text-xs font-display font-bold text-muted/30 mb-8 tracking-[0.2em]">{item.step}</p>
              <h3 class="text-display-md text-ink mb-4">{item.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─── CONTACT / CTA ───────────────────────────────────── -->
    <section id="contact" class="py-24 sm:py-32 border-t border-border" data-track-section="contact">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <!-- Left: copy -->
          <div class="animate-on-scroll">
            <p class="section-label mb-4">Get a quote</p>
            <h2 class="text-display-lg text-ink mb-6">
              Ready to get more<br />work from your website?
            </h2>
            <p class="text-base text-muted leading-relaxed mb-10 max-w-sm">
              Fill in the form and we'll get back to you within 1 business day.
              No pressure — just a conversation.
            </p>

            <ul class="space-y-4">
              {[
                'Free quote, no obligation',
                '2–4 week delivery',
                'Built for Australian businesses',
              ].map((point) => (
                <li class="flex items-center gap-3">
                  <span class="w-5 h-5 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                    <svg class="w-3 h-3 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </span>
                  <span class="text-sm text-muted">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: form -->
          <div class="animate-on-scroll" style="transition-delay: 0.15s">
            <ContactForm variant="light" />
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
