---
export interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;

const isLight = variant === 'light';

const inputClass = isLight
  ? 'form-input'
  : 'w-full bg-white/10 border border-white/20 text-paper placeholder-paper/40 px-4 py-3 text-sm font-body focus:outline-none focus:border-paper/60 transition-colors duration-150';

const labelClass = isLight
  ? 'form-label'
  : 'block text-xs font-display font-bold uppercase tracking-wider text-paper/50 mb-2';
---

<form
  action="https://formspree.io/f/xdawvnej"
  method="POST"
  data-contact-form
  class="space-y-5"
  novalidate
>
  <!-- Spam prevention -->
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
  <input type="hidden" name="_subject" value="New enquiry — Anchor Websites" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="form-name" class={labelClass}>Name *</label>
      <input
        type="text"
        id="form-name"
        name="name"
        placeholder="Your name"
        class={inputClass}
        autocomplete="name"
      />
      <p data-error-name class="hidden text-xs text-red-500 mt-1.5">Please enter your name.</p>
    </div>
    <div>
      <label for="form-phone" class={labelClass}>Phone</label>
      <input
        type="tel"
        id="form-phone"
        name="phone"
        placeholder="0400 000 000"
        class={inputClass}
        autocomplete="tel"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="form-email" class={labelClass}>Email</label>
      <input
        type="email"
        id="form-email"
        name="email"
        placeholder="you@example.com"
        class={inputClass}
        autocomplete="email"
      />
      <p data-error-email class="hidden text-xs text-red-500 mt-1.5">Please enter a valid email address.</p>
    </div>
    <div>
      <label for="form-suburb" class={labelClass}>Suburb</label>
      <input
        type="text"
        id="form-suburb"
        name="suburb"
        placeholder="Your suburb"
        class={inputClass}
        autocomplete="address-level2"
      />
    </div>
  </div>
  <p data-error-contact class="hidden text-xs text-red-500 -mt-2">Please enter an email or phone number so we can reach you.</p>

  <div>
    <label for="form-message" class={labelClass}>Message</label>
    <textarea
      id="form-message"
      name="message"
      rows="4"
      placeholder="Tell us about your business and what you need from your website..."
      class={`${inputClass} resize-none`}
    ></textarea>
  </div>

  <div>
    <button
      type="submit"
      data-form-submit
      class={isLight
        ? 'btn-primary py-3.5 px-8'
        : 'inline-flex items-center gap-2 bg-accent text-white font-display font-bold px-8 py-3.5 text-sm tracking-wide uppercase transition-all duration-200 hover:bg-accent-hover'}
    >
      Send message
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </button>
  </div>

  <div
    data-form-success
    role="alert"
    class="hidden p-4 bg-green-50 border border-green-200 text-green-800 text-sm font-body"
  >
    Thanks — we'll be in touch within 1 business day.
  </div>

  <div
    data-form-error
    role="alert"
    class="hidden p-4 bg-red-50 border border-red-200 text-red-800 text-sm font-body"
  >
    Something went wrong. Please try again or email us directly.
  </div>
</form>

<script>
  import Analytics from '../utils/analytics';

  const SUBMIT_LABEL = `Send message <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>`;

  function initForm(form: HTMLFormElement) {
    const successEl  = form.querySelector<HTMLElement>('[data-form-success]');
    const errorEl    = form.querySelector<HTMLElement>('[data-form-error]');
    const submitBtn  = form.querySelector<HTMLButtonElement>('[data-form-submit]');
    const nameInput  = form.querySelector<HTMLInputElement>('[name="name"]');
    const emailInput = form.querySelector<HTMLInputElement>('[name="email"]');
    const phoneInput = form.querySelector<HTMLInputElement>('[name="phone"]');
    const errorName    = form.querySelector<HTMLElement>('[data-error-name]');
    const errorContact = form.querySelector<HTMLElement>('[data-error-contact]');
    const errorEmail   = form.querySelector<HTMLElement>('[data-error-email]');

    Analytics.initFormTracking(form);

    function clearError(errEl: HTMLElement | null, inputEl: HTMLInputElement | null) {
      errEl?.classList.add('hidden');
      inputEl?.classList.remove('border-red-400');
    }

    nameInput?.addEventListener('input',  () => clearError(errorName, nameInput));
    emailInput?.addEventListener('input', () => {
      clearError(errorContact, null);
      clearError(errorEmail, emailInput);
    });
    phoneInput?.addEventListener('input', () => clearError(errorContact, null));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nameVal  = nameInput?.value.trim()  ?? '';
      const emailVal = emailInput?.value.trim()  ?? '';
      const phoneVal = phoneInput?.value.trim()  ?? '';
      let valid = true;

      if (!nameVal) {
        errorName?.classList.remove('hidden');
        nameInput?.classList.add('border-red-400');
        valid = false;
      } else {
        clearError(errorName, nameInput);
      }

      if (!emailVal && !phoneVal) {
        errorContact?.classList.remove('hidden');
        valid = false;
      } else {
        errorContact?.classList.add('hidden');
      }

      if (emailVal && !emailInput?.validity.valid) {
        errorEmail?.classList.remove('hidden');
        emailInput?.classList.add('border-red-400');
        valid = false;
      } else {
        clearError(errorEmail, emailInput);
      }

      if (!valid) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }
      successEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (import.meta.env.DEV) {
          const body = await res.clone().json().catch(() => res.clone().text());
          console.log('[ContactForm] Formspree response:', res.status, body);
        }

        if (res.ok) {
          form.reset();
          successEl?.classList.remove('hidden');
          Analytics.formSuccess();
        } else {
          throw new Error(`${res.status}`);
        }
      } catch (err) {
        if (import.meta.env.DEV) console.error('[ContactForm] submission error:', err);
        errorEl?.classList.remove('hidden');
        Analytics.formError();
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = SUBMIT_LABEL;
        }
      }
    });
  }

  document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach(initForm);
</script>
